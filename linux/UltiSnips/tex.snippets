global !p
import vim

def math():
    if vim.current.buffer.options['filetype'] == 'tex':
        if vim.eval('vimtex#syntax#in_mathzone()') == '0':
            return False
    else:
        try:
            if 'math' not in vim.eval("execute('Inspect')").lower():
                return False
        except:
            return False

    line = vim.current.line
    cursor_byte = vim.current.window.cursor[1]
    cursor_char = len(line.encode('utf-8')[:cursor_byte].decode('utf-8', 'ignore'))

    depth = 0
    for i in range(min(cursor_char - 1, len(line) - 1), -1, -1):
        char = line[i]
        if char == '$':
            return True
        if char == '}':
            depth += 1
        elif char == '{':
            if depth == 0:
                if i >= 5 and line[i-5:i] == '\\text':
                    return False
                if i >= 7 and (line[i-7:i] == '\\textbf' or line[i-7:i] == '\\textit'):
                    return False
            else:
                depth -= 1
    return True
endglobal

snippet template "Basic template" b
\documentclass{article}
\input{preamble}

\title{$1}
\author{Lorenzo Zambardi}
\date{A.A. $2}

\begin{document}

\maketitle

\pagebreak

$0

\end{document}
endsnippet

snippet beg "begin{} / end{}" bA
\begin{$1}
	$0
\end{$1}
endsnippet

priority 100
snippet ... "ldots" iA
\ldots
endsnippet

snippet table "Table environment" b
\begin{table}[${1:htpb}]
	\centering
	\caption{${2:caption}}
	\label{tab:${3:label}}
	\begin{tabular}{${5:c}}
	$0${5/((?<=.)c|l|r)|./(?1: & )/g}
	\end{tabular}
\end{table}
endsnippet

snippet fig "Figure environment" b
\begin{figure}[${1:htpb}]
	\centering
	${2:\includegraphics[width=0.8\textwidth]{$3}}
	\caption{${4:$3}}
	\label{fig:${5:${3/\W+/-/g}}}
\end{figure}
endsnippet

