snippet mk "Math" wA
$${1}$`!p
if t[2] and t[2][0] not in [',', '.', '?', '-', ' ']:
	snip.rv = ' '
else:
	snip.rv = ''
`$2
endsnippet

snippet dm "Math" wA
`!p
if snip.ft == "markdown":
    snip.rv = "$$"
else:
    snip.rv = "\\["
`
${1:${VISUAL}}
`!p
if snip.ft == "markdown":
    snip.rv = "$$"
else:
    snip.rv = "\\]"
` $0
endsnippet

